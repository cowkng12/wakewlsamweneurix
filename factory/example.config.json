    "CRYPTO_PAY_TOKEN": "CRYPTO_PAY_TOKEN"
  },
  "colors": {
    "primary": "#2563eb",
    "bright": "#38bdf8",
    "deep": "#1d4ed8"
  },
  "supabase": {
    "includeInRender": true
  },
  "git": {
    "init": true,
    "commitMessage": "Prepare NervaHub mini app"
  }
